# Adelaide Climate Analysis
library(tidyverse)
month <- c("Jan","Feb","Mar","Apr","May","Jun",
"Jul","Aug","Sep","Oct","Nov","Dec")
mean_temp <- c(28.3,28.1,25.6,22.3,18.6,16.0,
15.0,16.0,18.3,21.2,24.0,25.9)
temperature_data <- data.frame(
Month = month,
Temperature = mean_temp
)
figure1 <- ggplot(temperature_data,
aes(x = Month,
y = Temperature,
group = 1)) +
geom_line() +
geom_point() +
labs(
title = "Mean Monthly Temperature in Adelaide",
x = "Month",
y = "Temperature (°C)"
) +
theme_minimal()
figure1
install.packages("tidyverse")
install.packages("tidyverse")
setwd("C:/Users/yuan1/Desktop/EDA-Adelaide-Climate-Project")
library(tidyverse)
library(readxl)
# Read data
temp_data <- read_excel(
"data/adelaide_temperature.xlsx",
sheet = "Table001 (Page 1-2)"
)
# Convert wide data to long data
long_data <- temp_data %>%
pivot_longer(
cols = Jan:Dec,
names_to = "Month",
values_to = "Temperature"
)
long_data$Month <- factor(
long_data$Month,
levels = c("Jan", "Feb", "Mar", "Apr", "May", "Jun",
"Jul", "Aug", "Sep", "Oct", "Nov", "Dec")
)
# Figure 1: Mean monthly temperature
monthly_mean <- long_data %>%
group_by(Month) %>%
summarise(mean_temp = mean(Temperature, na.rm = TRUE))
figure1 <- ggplot(monthly_mean, aes(x = Month, y = mean_temp, group = 1)) +
geom_line() +
geom_point() +
labs(
title = "Mean Monthly Temperature in Adelaide",
x = "Month",
y = "Temperature (°C)"
) +
theme_minimal()
ggsave("output/figure1.png", plot = figure1, width = 7, height = 5)
# Figure 2: Monthly temperature distribution
figure2 <- ggplot(long_data, aes(x = Month, y = Temperature)) +
geom_boxplot() +
labs(
title = "Monthly Temperature Distribution in Adelaide",
x = "Month",
y = "Temperature (°C)"
) +
theme_minimal()
ggsave("output/figure2.png", plot = figure2, width = 7, height = 5)
# Figure 3: Seasonal amplitude
temp_data <- temp_data %>%
mutate(
Summer = rowMeans(select(., Dec, Jan, Feb), na.rm = TRUE),
Winter = rowMeans(select(., Jun, Jul, Aug), na.rm = TRUE),
Amplitude = Summer - Winter
)
figure3 <- ggplot(temp_data, aes(x = Year, y = Amplitude)) +
geom_line() +
geom_smooth(method = "lm", se = FALSE) +
labs(
title = "Seasonal Amplitude Trend in Adelaide",
x = "Year",
y = "Amplitude (°C)"
) +
theme_minimal()
ggsave("output/figure3.png", plot = figure3, width = 7, height = 5)
