library(tidyverse)
# ① 计算每年最热 & 最冷
year_extreme <- long_data %>%
group_by(Year) %>%
summarise(
max_temp = max(Temp, na.rm = TRUE),
min_temp = min(Temp, na.rm = TRUE)
)
# ② 画图（最热+最冷+拟合）
ggplot(year_extreme, aes(x = Year)) +
geom_line(aes(y = max_temp, colour = "Hottest")) +
geom_line(aes(y = min_temp, colour = "Coldest")) +
geom_smooth(aes(y = max_temp), method = "lm", se = FALSE, linetype="dashed") +
geom_smooth(aes(y = min_temp), method = "lm", se = FALSE, linetype="dashed") +
scale_colour_manual(values = c("Hottest"="red","Coldest"="blue")) +
theme_minimal() +
labs(y="Temperature", colour="Legend")
geom_point(aes(y=max_temp, colour="Hottest"))
geom_point(aes(y=min_temp, colour="Coldest"))
lm(max_temp ~ Year, data = year_extreme)
lm(min_temp ~ Year, data = year_extreme)
geom_point(data = year_extreme %>% filter(max_temp==max(max_temp)),
aes(y=max_temp), colour="black", size=3)
long_data %>%
filter(Temp > 30 | Temp < 10)
season_amp <- long_data %>%
mutate(Season = case_when(
Month %in% c("Dec","Jan","Feb") ~ "Summer",
Month %in% c("Jun","Jul","Aug") ~ "Winter"
)) %>%
filter(!is.na(Season)) %>%
group_by(Year, Season) %>%
summarise(mean_temp = mean(Temp, na.rm=TRUE)) %>%
pivot_wider(names_from=Season, values_from=mean_temp) %>%
mutate(amplitude = Summer - Winter)
